{
  extends: ["github>cloudquery/.github//.github/renovate-default.json5"],
  python: {
    enabled: false,
  },
  packageRules: [
    {
      matchPackageNames: ["^grpcio"],
      groupName: "grpcio",
    },
    {
      "matchPackageNames": ["python"],
      "allowedVersions": "<3.14"
    }
  ],
}
